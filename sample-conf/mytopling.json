{
  "http": {
    "document_root": "/nvme-shared/mytopling/log",
    "hide_files_patterns": "*.sst|*.dbtmp",
    "num_threads": "50",
    "listening_ports": "2013"
  },
  "setenv": {
    "DictZipBlobStore_zipThreads": 32
  },
  "permissions": {
    "web_compact": true,
    "//end": "end"
  },
  "AnyPlugin": {
    "sys_info": "SysInfoShower",
    "git_info": "GitInfoShower",
    "hex_key_coder": {
      "class": "HexUserKeyCoder",
      "params": { "prefix_len": 4, "max_width": 40 }
    },
    "pretty": {
      "class": "PrettyHexUserKeyCoder",
      "params": { "prefix_len": 4}
    },
    "sys_cf_key_coder": "HtmlTextUserKeyCoder",
    "html_text_key_coder": "HtmlTextUserKeyCoder"
  },
  "Statistics": {
    "stat": {
      "class": "default",
      "params": {
        "discard_tickers": [
          "# comment",
          "// comment: 可以仅指定前缀，必须是以 . 为边界的前缀，例如下面两个必须分别指定",
          "rocksdb.block.cache",
          "rocksdb.block.cachecompressed",
          "# comment: 上面两个也可以用下面这一个概括",
          "rocksdb.block",
          "# 精确指定",
          "rocksdb.memtable.payload.bytes.at.flush",
          "rocksdb.memtable.garbage.bytes.at.flush",
          "rocksdb.blobdb",
          "rocksdb.row.cache",
          "rocksdb.number.block",
          "rocksdb.bloom.filter",
          "rocksdb.persistent",
          "rocksdb.sim.block.cache"
        ],
        "discard_histograms": [
          "# comment: ....",
          "rocksdb.blobdb",
          "rocksdb.bytes.compressed",
          "rocksdb.bytes.decompressed",
          "rocksdb.num.index.and.filter.blocks.read.per.level",
          "rocksdb.num.data.blocks.read.per.level",
          "rocksdb.compression.times.nanos",
          "rocksdb.decompression.times.nanos",
          "rocksdb.read.block.get.micros",
          "rocksdb.write.raw.block.micros",
          "# comment end of array"
        ],
        "//stats_level": "kExceptHistogramOrTimers",
        "--stats_level": "kExceptTimeForMutex",
        "stats_level": "kExceptDetailedTimers"
      }
    }
  },
  "CompactionFilterFactory": {
    "compact_filter": {
      "class": "Rdb_compact_filter_factory",
      "params": {}
    }
  },
  "Cache": {
    "block_cache": {
      "class": "LRUCache",
      "params": {
        "capacity": "8G",
        "num_shard_bits": -1,
        "strict_capacity_limit": false,
        "high_pri_pool_ratio": 0.0,
        "use_adaptive_mutex": false,
        "metadata_charge_policy": "kFullChargeCacheMetadata"
      }
    }
  },
  "Comparator": {
    "bytewise": {
      "class": "BytewiseComparator",
      "params": {
        "need-not-any-param": "keep empty"
      }
    },
    "rev": {
      "class": "ReverseBytewiseComparator",
      "params": {
        "need-not-any-param": "used for rev cf"
      }
    }
  },
  "TableFactory": {
    "auto_sort": {
      "class": "VecAutoSortTable",
      "params": {
        "debugLevel": 0,
        "minUserKeyLen": 4,
        "fileWriteBufferSize": "64K",
        "collectProperties": false,
        "forceNeedCompact": true
      }
    },
    "bb": {
      "class": "BlockBasedTable",
      "params": {
        "cache_index_and_filter_blocks": true,
        "pin_l0_filter_and_index_blocks_in_cache": true,
        "block_cache": "${block_cache}",
        "//index_type": "kTwoLevelIndexSearch",
        "//block_size": "8K"
      }
    },
    "sng": {
      "class": "SingleFastTable",
      "params": {
        "minPreadLen": -1,
        "maxPreadLen": 32768,
        "minPreadLevel": 1,
        "collectPropertiesMinLevel": 2,
        "needCompactOnOmitPropsCollector": true,
        "accurateKeyAnchorsSize": true,
        "keyAnchorSizeUnit": "100K"
      }
    },
    "light_dzip": {
      "comment1": "Disable value zip for faster compression speed",
      "comment2": "Index and Tag(Seq+ValueType) will still be compressed",
      "class": "ToplingZipTable",
      "params": {
        "//localTempDir": "/tmp",
        "builderMinLevel": 0,
        "//needCompactMaxLevel": 2,
        "acceptCompressionRatio": 0.8,
        "enableFixedLenHoleIndex": true,
        "enableUintIndex": true,
        "enableStatistics": false,
        "warmupLevel": "kIndex",
        "optimizeCpuL3Cache": true,
        "offsetArrayBlockUnits": 0,
        "sampleRatio": 0.01,
        "keyRankCacheRatio": 0.001,
        "checksumLevel": 0,
        "entropyAlgo": "kNoEntropy",
        "debugLevel": 0,
        "large minDictZipValueSize will disable value zip": "10M",
        "minDictZipValueSize": "10M",
        "keyPrefixLen": 4,
        "minPreadLen": -1
      }
    },
    "dzip": {
      "class": "ToplingZipTable",
      "params": {
        "//localTempDir": "/tmp",
        "enableFixedLenHoleIndex": true,
        "enableUintIndex": true,
        "//indexType": "SE_512_64",
        "indexNestLevel": 3,
        "//indexNestScale": 1,
        "//indexMemAsHugePage": true,
        "indexMemAsResident": false,
        "builderMinLevel": 0,
        "//needCompactMaxLevel": 2,
        "acceptCompressionRatio": 0.8,
        "enableStatistics": false,
        "warmupLevel": "kIndex",
        "optimizeCpuL3Cache": true,
        "offsetArrayBlockUnits": 128,
        "sampleRatio": 0.01,
        "//sampleRatio": [0.02, 0.01, 0.007, 0.005, 0.002],
        "keyRankCacheRatio": 0.001,
        "checksumLevel": 0,
        "entropyAlgo": "kNoEntropy",
        "debugLevel": 0,
        "minDictZipValueSize": "30",
        "keyPrefixLen": 4,
        "minPreadLen": -1
      }
    },
    "cspp_memtab_sst": {
      "class": "CSPPMemTabTable",
      "params": { }
    },
    "dispatch": {
      "class": "DispatcherTable",
      "params": {
        "default": "sng",
        "auto_compaction_max_wamp-comment": "may cause compactions can not be scheduled",
        "//auto_compaction_max_wamp": 10,
        "mark_for_compaction_max_wamp": 30,
        "trivial_move_always_max_output_level": 5,
        "trivial_move_max_file_size_multiplier": 4,
        "readers": {
          "VecAutoSortTable": "auto_sort",
          "CSPPMemTabTable": "cspp_memtab_sst",
          "BlockBasedTable": "bb",
          "SingleFastTable": "sng",
          "ToplingZipTable": "dzip"
        },
        "comment aaa": [
          "light_dzip", "light_dzip",
          "light_dzip",
          "bb", "bb", "bb", "bb", "bb", "bb", "bb", "bb", "bb", "bb",
          "bb"
        ],
        "level_writers": [
          "sng", "sng",
          "dzip", "dzip", "dzip", "dzip", "dzip"
        ]
      }
    }
  },
  "MemTableRepFactory": {
    "dyna": {
      "class": "Dyna",
      "params": { "real_fac": "${cspp}" }
    },
    "cspp": {
      "class": "cspp",
      "params": {
        "mem_cap": "6G",
        "chunk_size": "256K",
        "use_vm": true,
        "vm_explicit_commit": true,
        "use_hugepage": true,
        "//0 convert_to_sst": "kDontConvert is the default",
        "//1 convert_to_sst": "kDontConvert",
        "//2 convert_to_sst": "kDumpMem",
        "convert_to_sst": "kFileMmap",
        "sync_sst_file": false,
        "read_by_writer_token": true,
        "token_use_idle": true
      }
    },
    "cspp_small": {
      "class": "cspp",
      "params": {
        "mem_cap": "32M",
        "chunk_size": "32K",
        "use_vm": true,
        "use_hugepage": false,
        "read_by_writer_token": true,
        "token_use_idle": true
      }
    },
    "skiplist": {
      "class": "SkipList",
      "params": { "lookahead": 0 }
    }
  },
  "WBWIFactory": {
    "cspp": {
      "class": "CSPP_WBWI",
      "params": {
        "data_max_cap": "2G",
        "trie_reserve_cap": "128K",
        "data_reserve_cap": "512K"
      }
    },
    "skiplist": {
      "class": "SkipList",
      "params": {}
    },
    "pair_check": {
      "class": "PairCheckWBWI",
      "params": {
        "a": "${skiplist}",
        "b": "${cspp}"
      }
    }
  },
  "MergeOperator": {
    "system_merge_op": {
      "class": "Rdb_system_merge_op",
      "params": {}
    }
  },
  "TablePropertiesCollectorFactory": {
    "tbl_prop_coll": {
      "class": "Rdb_tbl_prop_coll_factory",
      "params": {}
    }
  },
  "SstPartitionerFactory": {
    "rdb_partitioner": {
      "class": "Rdb_sst_partitioner_factory",
      "params": {
        "comparator": "${bytewise}"
      }
    },
    "rdb_rev_partitioner": {
      "class": "Rdb_sst_partitioner_factory",
      "params": {
        "comparator": "${rev}"
      }
    },
    "by_prefix": {
      "class": "FixedPrefix",
      "params": {
        "user_key_at_least_prefix_len": true,
        "prefix_len": 4,
        "//max_level": 2,
        "min_file_size": 0
      }
    }
  },
  "RateLimiter": {
    "rate_limiter": {
      "class": "GenericRateLimiter",
      "params": {
        "rate_bytes_per_sec": "40M"
      }
    }
  },
  "CFOptions": {
    "default": {
      "enable_blob_garbage_collection": true,
      "num_levels": 7,
      "max_bytes_for_level_multiplier": 1,
      "max_bytes_for_level_multiplier_additional": [1,3,5,7,10,10,10,10],
      "min_filter_level": 2,
      "disable_auto_compactions": true,
      "level0_file_num_compaction_trigger": 4,
      "//level0_slowdown_writes_trigger": 8,
      "//level0_stop_writes_trigger": 16,
      "//max_bytes_for_level_base": "512M",
      "//level_compaction_dynamic_level_bytes": true,
      "-compaction_pri": "kByCompensatedSize",
      "compaction_pri": "kMinOverlappingRatio",
      "//compaction_pri": "kMinOverlappingBytes",
      "memtable_factory": "${dyna}",
      "max_write_buffer_number": 4, "write_buffer_size": "2560M",
      "max_write_buffer_size_to_maintain": "256M",
      "target_file_size_base": "32M", "target_file_size_multiplier": 2.3,
      "level_compaction_dynamic_file_size": false,
      "soft_pending_compaction_bytes_limit": "1T",
      "hard_pending_compaction_bytes_limit": "2T",
      "table_factory": "${dispatch}",
      "html_user_key_coder": "${hex_key_coder}",
      "//html_user_key_coder": "${pretty}",
      "table_properties_collector_factories": [ "${tbl_prop_coll}" ],
      "check_flush_compaction_key_order": false,
      "paranoid_file_checks": false,
      "sst_partitioner_factory": "by_prefix",
      "compaction_executor_factory": "dcompact",
      "compaction_filter_factory": "${compact_filter}"
    },
    "encrypt": {
      "template": "${default}",
      "cf_paths": "/nvme-shared/mytopling/encrypt"
    },
    "default_sk": {
      "template": "${default}",
      "//cf_paths": "/nvme-shared/mytopling/default_sk"
    },
    "rev:order": {
      "template": "${default}",
      "comparator": "${rev}"
    },
    "__tmp__": {
      "template": "${default}",
      "//cf_paths": "/nvme-shared/mytopling/__tmp__"
    },
    "__system__": {
      "enable_blob_garbage_collection": true,
      "num_levels": 7, "max_bytes_for_level_multiplier": 10,
      "disable_auto_compactions": true,
      "level0_file_num_compaction_trigger": 4,
      "memtable_factory": "${cspp_small}",
      "max_write_buffer_number": 2, "write_buffer_size": "16M",
      "target_file_size_base": "16M", "target_file_size_multiplier": 2,
      "table_factory": "${dispatch}",
      "check_flush_compaction_key_order": true,
      "paranoid_file_checks": true,
      "merge_operator": "${system_merge_op}"
    },
    "__tmp_system__": {
      "template": "${__system__}",
      "//cf_paths": "/nvme-shared/mytopling/__tmp_system__"
    },
    "sample": {
      "template": "default",
      "cf_paths": "/path/to/sample/cf"
    }
  },
  "DBOptions": {
    "dbopt": {
      "allow_fdatasync": false,
      "advise_random_on_open": true,
      "create_if_missing": true,
      "create_missing_column_families": true,
      "delayed_write_rate": "16M",
      "info_log_level": "DEBUG_LEVEL",
      "max_background_flushes": 2,
      "max_background_compactions": 32,
      "max_subcompactions": 1,
      "max_level1_subcompactions": 3,
      "max_level1_subcompactions nas": 13,
      "max_log_file_size": "256M",
      "keep_log_file_num": 100,
      "memtable_as_log_index": true,
      "max_total_wal_size": "5G",
      "db_write_buffer_size": "2560M",
      "//rate_limiter": "${rate_limiter}",
      "verify_sst_unique_id_in_manifest": false,
      "//write_buffer_manager": "${wbm}",
      "inplace_update_support": false,
      "WAL_size_limit_MB": 0,
      "//wal_dir": "/dev/shm/mytopling/wal",
      "//db_paths" : [
        "/path/to/local/filesystem/for/level/0",
        "/path/to/nfs/filesystem/for/level/1",
        "/path/to/nfs/filesystem/for/level/2/to/level/n"
      ],
      "db_log_dir": "/nvme-shared/mytopling/log/.rocksdb",
      "wbwi_factory": "${cspp}",
      "statistics": "${stat}",
      "manual_wal_flush": true,
      "two_write_queues": true,
      "allow_mmap_reads": false
    }
  },
  "TransactionDBMutexFactory": {
    "mtx_fac": {
      "class": "Rdb_mutex_factory",
      "params": {}
    }
  },
  "databases": {
    ".rocksdb": {
      "method": "TransactionDB::Open",
      "params": {
        "db_options": "${dbopt}",
        "txn_db_options": {
          "key_prefix_len": 4,
          "super_stripes": 1,
          "num_stripes": 19,
          "transaction_lock_timeout": 2000,
          "custom_mutex_factory": "${mtx_fac}"
        },
        "column_families": {
          "default": "${default}",
          "__system__": "${__system__}"
        },
        "//column_families": {
          "default": "${default}",
          "__system__": "${__system__}",
          "default_sk": "${default}",
          "__tmp__": "${__tmp__}",
          "__tmp_system__": "${__system__}",
          "encrypt": "${encrypt}",
          "rev:order": "${rev:order}"
        }
      }
    }
  },
  "open": "${.rocksdb}",
  "CompactionExecutorFactory": {
    "dcompact": {
      "class": "DcompactEtcd",
      "params": {
        "allow_fallback_to_local": true,
        "//info_log_level": "DEBUG_LEVEL",
        "estimate_speed": "10M",
        "timeout_multiplier": 5.0,
        "//copy_sst_files": true,
        "copy_sst_files oss": true,
        "copy_sst_files nfs": false,
        "hoster_root": "/nvme-shared/mytopling/datadir",
        "instance_name": "datadir",
        "///hoster_root": "/ram-shared/mytopling/copydir",
        "///instance_name": "copydir",
        "///copy_sst_files": true,
        "oneshot_dbname_prefix": "default-",
        "nfs_mnt_src": "static-mounted",
        "nfs_mnt_opt": "",
        "alert_email": "20409170@qq.com",
        "//alert_http": "https://dcompact.alert.com/dcompact-alert",
        "web_domain": "topling.in",
        "job_url_root": "http://192.168.31.100:8080",
        "overall_timeout": 30,
        "http_max_retry": 3,
        "http_timeout": 5,
        "http_workers": [
          "//http://127.0.0.1:8080",
          "http://192.168.31.100:8080",
          { "url": "http://192.168.31.2:8080", "weight": 50 },
          { "url": "http://192.168.31.3:8080", "weight": 90 },
          { "url": "//http://192.168.100.116:8081", "web_url": "http://dell3.topling.in:2011" },
          { "url": "//http://192.168.100.117:8081", "base_url": "http://192.168.31.3:55071", "web_url": "http://dell3.topling.in:2011" },
          "//http://192.168.100.102:8080",
          "//http://192.168.100.102:8081",
          "//http://commented-host:8080",
          "//end_http_workers"
        ],
        "dcompact_http_headers": {
          "Header1": "value1",
          "Header2": "value2"
        },
        "//load_balance": "kRoundRobin",
        "load_balance": "kWeight",
        "dcompact_min_level": 2
      }
    },
    "dcompact2" : {
      "class": "DcompactEtcd",
      "params": {
        "template": "${dcompact}"
      }
    }
  }
}
